# =============================================================================
# CONFIGURACIÓN DEL CLIENTE TCP - STORAGE CLUSTER
# =============================================================================
# Copia este archivo a .env y ajusta los valores según tu entorno
# 
# IMPORTANTE: 
# - CLIENT_ID es OBLIGATORIO y debe ser único para cada cliente (CLIENT_001 a CLIENT_009)
# - El archivo .env NO debe subirse a git (ya está en .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# IDENTIFICACIÓN DEL CLIENTE
# -----------------------------------------------------------------------------
# ID único del cliente (OBLIGATORIO)
# Formato: CLIENT_XXX donde XXX es un número de 001 a 009
CLIENT_ID=CLIENT_001

# -----------------------------------------------------------------------------
# CONEXIÓN AL SERVIDOR
# -----------------------------------------------------------------------------
# Host del servidor TCP central
SERVER_HOST=localhost

# Puerto del servidor TCP
SERVER_PORT=5000

# -----------------------------------------------------------------------------
# INTERVALOS Y TIMEOUTS
# -----------------------------------------------------------------------------
# Intervalo de envío de métricas en milisegundos (30 segundos = 30000)
METRICS_INTERVAL=30000

# Intervalo de reconexión en milisegundos (5 segundos = 5000)
RECONNECT_INTERVAL=5000

# Máximo de intentos de reconexión (-1 = infinito)
MAX_RECONNECT_ATTEMPTS=-1

# Timeout para recepción de mensajes en milisegundos
MESSAGE_TIMEOUT=30000

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# Nivel de log: error, warn, info, debug
LOG_LEVEL=info

# Archivo de log principal
LOG_FILE=logs/client.log

# Archivo de log de mensajes del servidor
MESSAGES_LOG_FILE=logs/messages.log

# -----------------------------------------------------------------------------
# AMBIENTE
# -----------------------------------------------------------------------------
# Ambiente de ejecución: development, production, test
NODE_ENV=development
